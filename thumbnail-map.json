      "homepage": {
        "goal": "hook",
        "needs": [
          "strongest single focal point",
          "highest contrast",
          "fastest readability",
          "simplest composition"
        ]
      },
      "reel": {
        "goal": "recognition",
        "needs": [
          "project identity",
          "readable evidence",
          "neighboring-card rhythm"
        ]
      },
      "hero": {
        "goal": "depth",
        "needs": [
          "fuller project context",
          "richer evidence",
          "implementation proof"
        ]
      }
    },
    "status_values": [
      "artifact",
      "derived",
      "fallback"
    ],
    "selection_order": [
      "real gameplay",
      "real UI",
      "charts/results",
